{
  "name": "@picoflow/agent-wallet",
    "version": "0.2.0",
  "description": "Buyer-side helper for x402 paid HTTP calls on Circle Arc. Wraps EIP-3009 signing, optional /price_quote negotiation, automatic 402-retry, and balance checks. Pairs with @picoflow/x402-facilitator on the seller side.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "test": "node --test --import tsx src/__tests__/*.test.ts"
  },
  "dependencies": {
    "@picoflow/x402-facilitator": "workspace:*",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
    "publishConfig": {
      "access": "public"
    },
  "keywords": [
    "x402",
    "http-402",
    "agent",
    "wallet",
    "circle",
    "arc",
    "usdc",
    "eip-3009",
    "buyer",
    "agentic"
  ]
}
