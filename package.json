{
  "name": "picoflow",
  "version": "0.2.0",
  "private": true,
  "description": "PicoFlow — The Agentic Settlement Mesh on Arc. Sub-cent USDC nanopayments for AI agents via x402 + Circle Gateway.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10",
      "uuid": ">=14.0.0"
    }
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "docs:whitepaper": "node scripts/build-whitepaper.mjs",
    "docs:pitch": "node scripts/build-pitch.mjs",
    "docs:all": "pnpm docs:whitepaper && pnpm docs:pitch",
    "docs:bundle": "node scripts/build-docs.mjs",
    "vultr:inventory": "tsx scripts/vultr/inventory.ts",
    "vultr:provision": "tsx scripts/vultr/provision.ts",
    "demo:run": "tsx scripts/run-demo.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0"
  }
}
