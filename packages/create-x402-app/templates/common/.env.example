# Buyer's wallet — generate a fresh test EOA via:
#   node -e "console.log(require('viem/accounts').generatePrivateKey())"
BUYER_PRIVATE_KEY=

# Where the seller server is reachable (when running locally, leave default)
SELLER_BASE=http://127.0.0.1:3030

# Arc Testnet RPC (Circle Sandbox)
ARC_RPC=https://rpc.testnet.arc.network

# Seller's payout address (any EVM address — this is who receives USDC).
SELLER_ADDR=0x000000000000000000000000000000000000abcd

# Server port
PORT=3030
